# Desktop Application Configuration
# Copy this file to .env in the backend directory when building for desktop
#
# NOTE: Settings like anthropic_api_key, default_model, claude_code_use_bedrock,
# and sandbox_* have moved to ~/.swarm-ai/config.json (managed by AppConfigManager).
# Do NOT add them here — Settings(extra="forbid") will reject unknown fields.

# Application mode
DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000

# Database - Use SQLite for desktop
DATABASE_TYPE=sqlite

# CORS - Allow Tauri frontend
CORS_ORIGINS=["http://localhost:1420","tauri://localhost"]

# Rate limiting (can be more generous for local app)
RATE_LIMIT_PER_MINUTE=1000

# JWT - Still used for session tokens but auth is simplified
# IMPORTANT: Generate a secure random key for production use!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
