# SwarmAI Hive — Environment Configuration
#
# Copy to .env and customize before running setup.sh
# Most values have sensible defaults for EC2 deployment.

# ---------------------------------------------------------------------------
# Domain & Auth (required)
# ---------------------------------------------------------------------------

# Your domain — Caddy auto-provisions HTTPS via Let's Encrypt
HIVE_DOMAIN=hive.yourdomain.com

# Basic auth credentials (MVP — replace with Cognito/SSO later)
# Generate hash: caddy hash-password --plaintext 'your-password'
HIVE_USER=admin
HIVE_PASS_HASH=$2a$14$REPLACE_WITH_ACTUAL_HASH

# ---------------------------------------------------------------------------
# AWS Configuration
# ---------------------------------------------------------------------------

# AWS region for Bedrock Claude API
# Use IAM instance role for credentials — no access keys needed
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# SwarmAI Configuration
# ---------------------------------------------------------------------------

# Deployment mode (set automatically by swarmai-hive.sh)
SWARMAI_MODE=hive

# Backend port (default: 18321, same as daemon mode)
SWARMAI_PORT=18321

# Claude SDK configuration
CLAUDE_CODE_USE_BEDROCK=1
CLAUDE_CODE_DISABLE_AUTO_MEMORY=1

# ---------------------------------------------------------------------------
# Slack Bot (optional)
# ---------------------------------------------------------------------------
# Slack tokens are stored in the database, not env vars.
# Configure via /api/channels endpoint after first startup.
# Slack Socket Mode is outbound — no inbound port needed.

# ---------------------------------------------------------------------------
# Repository (for setup.sh)
# ---------------------------------------------------------------------------

# Override if using a fork or private repo
# SWARMAI_REPO_URL=https://github.com/xg-gh-25/SwarmAI.git
# SWARMAI_REPO_BRANCH=main
