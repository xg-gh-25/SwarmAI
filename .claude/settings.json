{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/reject-pytest-tail.sh",
            "timeout": 5,
            "statusMessage": "Checking pytest safety..."
          }
        ]
      }
    ]
  }
}
