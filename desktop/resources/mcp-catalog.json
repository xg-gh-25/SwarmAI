[
  {
    "id": "email",
    "name": "Email",
    "description": "Read, search, send, and manage email across Gmail, Outlook, iCloud, and IMAP/SMTP providers. 47 tools including triage, drafts, scheduling, and analytics.",
    "connection_type": "stdio",
    "category": "communication",
    "package": "@codefuturist/email-mcp",
    "config": {
      "command": "npx",
      "args": ["-y", "@codefuturist/email-mcp"]
    },
    "required_env": [
      { "key": "MCP_EMAIL_ADDRESS", "label": "Email address", "placeholder": "you@example.com" },
      { "key": "MCP_EMAIL_PASSWORD", "label": "App password", "placeholder": "xxxx-xxxx-xxxx-xxxx", "secret": true },
      { "key": "MCP_EMAIL_IMAP_HOST", "label": "IMAP host", "placeholder": "imap.gmail.com" },
      { "key": "MCP_EMAIL_SMTP_HOST", "label": "SMTP host", "placeholder": "smtp.gmail.com" }
    ],
    "optional_env": [
      { "key": "MCP_EMAIL_IMAP_PORT", "label": "IMAP port", "default": "993" },
      { "key": "MCP_EMAIL_SMTP_PORT", "label": "SMTP port", "default": "465" },
      { "key": "MCP_EMAIL_RATE_LIMIT", "label": "Max sends/min", "default": "10" }
    ],
    "presets": {
      "gmail": {
        "label": "Gmail",
        "env": { "MCP_EMAIL_IMAP_HOST": "imap.gmail.com", "MCP_EMAIL_SMTP_HOST": "smtp.gmail.com" },
        "setup_hint": "Use an App Password: Google Account → Security → 2FA → App Passwords"
      },
      "outlook": {
        "label": "Outlook / Hotmail",
        "env": { "MCP_EMAIL_IMAP_HOST": "outlook.office365.com", "MCP_EMAIL_SMTP_HOST": "smtp.office365.com", "MCP_EMAIL_SMTP_PORT": "587" },
        "setup_hint": "Enable IMAP in Outlook settings. Use your account password or an App Password."
      },
      "icloud": {
        "label": "iCloud Mail",
        "env": { "MCP_EMAIL_IMAP_HOST": "imap.mail.me.com", "MCP_EMAIL_SMTP_HOST": "smtp.mail.me.com", "MCP_EMAIL_SMTP_PORT": "587" },
        "setup_hint": "Generate an app-specific password at appleid.apple.com → Sign-In and Security"
      }
    },
    "setup_command": "npx @codefuturist/email-mcp setup"
  },
  {
    "id": "slack",
    "name": "Slack",
    "description": "Read, search, and send Slack messages. List channels, users, and threads. 11 tools with auto-token refresh on macOS.",
    "connection_type": "stdio",
    "category": "communication",
    "package": "@jtalk22/slack-mcp",
    "config": {
      "command": "npx",
      "args": ["-y", "@jtalk22/slack-mcp"]
    },
    "required_env": [
      { "key": "SLACK_TOKEN", "label": "Slack token (xoxc-...)", "placeholder": "xoxc-...", "secret": true },
      { "key": "SLACK_COOKIE", "label": "Slack cookie (xoxd-...)", "placeholder": "xoxd-...", "secret": true }
    ],
    "optional_env": [],
    "presets": {
      "macos_auto": {
        "label": "macOS auto-extract from Chrome",
        "env": {},
        "setup_hint": "Tokens are auto-extracted from Chrome on macOS. Just sign in to Slack in Chrome."
      }
    },
    "setup_command": "npx -y @jtalk22/slack-mcp --setup"
  },
  {
