      { "key": "TEAMS_APP_TYPE", "label": "Tenant type", "placeholder": "SingleTenant" },
      { "key": "TEAMS_APP_TENANT_ID", "label": "Tenant ID", "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
