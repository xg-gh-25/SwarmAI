{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwarmAI",
  "version": "1.9.0",
  "identifier": "com.swarmai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:full",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "externalBin": [
      "binaries/python-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCOUNFREI1RDNDNThBNEQKUldSTmlzWFR0ZTJjZS8ydVk0Y3UvUlFaRG83QlBUMU44NE45OGs5YWNJY09DZU9tTi9ocUdtbGYK",
      "endpoints": [
        "https://github.com/xg-gh-25/SwarmAI/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
